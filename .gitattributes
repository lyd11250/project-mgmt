# 统一行尾策略：仓库内文本一律存 LF，覆盖各机器的 core.autocrlf 设置，
# 避免 Windows 检出时被转成 CRLF 产生噪音 diff。
* text=auto eol=lf

# 显式声明常见文本类型（保险，便于 diff/合并）
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sql    text eol=lf
*.properties text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.vue    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.svg    text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.env*    text eol=lf
mvnw     text eol=lf

# Windows 批处理保持 CRLF
*.cmd    text eol=crlf
*.bat    text eol=crlf
mvnw.cmd text eol=crlf

# 二进制：不做行尾/文本处理
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.jar    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
