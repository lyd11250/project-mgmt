# Docker Compose 环境变量示例。复制为 .env 并按需修改（.env 不入库）。
# 生产环境务必修改默认密码。

DB_NAME=bedrock
DB_USER=bedrock
DB_PASSWORD=bedrock
REDIS_PASSWORD=

# MinIO 对象存储（生产务必修改默认密钥）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bedrock

# 后端激活的 Spring Profile：dev 或 prod
SPRING_PROFILES_ACTIVE=prod
